{
  "name": "03 File Uploader",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "upload",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "b6e46184-db35-4fac-8c21-a610cb39896a",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
